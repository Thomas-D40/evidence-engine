# Required
OPENAI_API_KEY=sk-...
ALLOWED_API_KEYS=your-api-key-here

# OpenAI models
OPENAI_MODEL=gpt-4o-mini
OPENAI_SMART_MODEL=gpt-4o

# Optional research API keys (services silently skipped if missing)
NEWSAPI_KEY=
GNEWS_API_KEY=
GOOGLE_FACTCHECK_API_KEY=
CLAIMBUSTER_API_KEY=

# Enrichment configuration
FULLTEXT_SCREENING_ENABLED=true
FULLTEXT_TOP_N=3
FULLTEXT_MIN_SCORE=0.6

# Adversarial query generation
ADVERSARIAL_QUERIES_ENABLED=true

# Server
HOST=0.0.0.0
PORT=8001
ENV=development
